PORT=4000
USE_MOCK=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EXTRACTION_DEBUG=false

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/gmail/callback
OAUTH_SUCCESS_REDIRECT=http://localhost:5173/
CLIENT_ORIGIN=http://localhost:5173

GMAIL_REFRESH_TOKEN=
GMAIL_ACCESS_TOKEN=
GMAIL_EXPIRY_DATE=

DEMO_GMAIL_REFRESH_TOKEN=
DEMO_GMAIL_ACCESS_TOKEN=
DEMO_GMAIL_EXPIRY_DATE=

GMAIL_TOKEN_FILE=.gmail-tokens.json

GMAIL_LIST_QUERY=in:inbox newer_than:14d
GMAIL_MAX_RESULTS=25
