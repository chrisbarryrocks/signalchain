{
  "name": "signalchain",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm-run-all build:server build:client",
    "build:client": "npm --workspace client run build",
    "build:server": "npm --workspace server run build",
    "lint": "npm-run-all lint:server lint:client",
    "lint:client": "npm --workspace client run lint",
    "lint:server": "npm --workspace server run lint",
    "typecheck": "npm-run-all typecheck:server typecheck:client",
    "typecheck:client": "npm --workspace client run typecheck",
    "typecheck:server": "npm --workspace server run typecheck"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}